# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.yarn/install-state.gz

# Testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
*.lcov
.nyc_output

# Next.js
/.next/
/out/
.next
.turbo

# Production
/build
/dist

# Misc
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files (can opt-in for committing if needed)
.env*
.env*.local
.env.development.local
.env.test.local
.env.production.local
# Public production URL is committed so `docker compose up --build` bakes it in.
!.env.production

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# IDE / Editor files
.vscode/settings.json
.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Cache directories
.cache
.parcel-cache
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.tailwindcss-cache

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# Parcel bundler cache
.parcel-cache

# Nuxt.js build / generate output
.nuxt

# Storybook build outputs
.out
.storybook-out
storybook-static

# Temporary folders
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.orig

# Local Netlify folder
.netlify

# Sentry
.sentryclirc

# Bundle analysis
.bundle-analysis/

# Local development
.local

# Database files
*.db
*.db-journal
*.sqlite
*.sqlite3

# AI/ML models (if any)
*.model
*.pkl
*.h5
*.pb

# Microbundle cache
web_modules/

# Snowpack dependency directory
jspm_packages/

# Lock files (keep package-lock.json but ignore others based on your package manager)
# yarn.lock
# pnpm-lock.yaml
